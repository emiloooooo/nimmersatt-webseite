# Unreferenced source videos in assets/ — the live site only plays the
# frame-sequence JPGs under frames/<slug>/. Keep the reference clips
# locally but never ship them. Whitelist loader.* + logo.svg explicitly
# because those ARE referenced from index.html.
assets/*.mp4
assets/*.mov
assets/*.mkv
assets/*.MP4
assets/*.MOV
# Re-include files that ARE referenced from the live site — preloader
# clip, logo, and every project video linked from PROJECTS in js/main.js.
!assets/loader.mp4
!assets/loader.webm
!assets/logo.svg
!assets/Charli Xcx Recap Full.mp4
