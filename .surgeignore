# web-assets are served from GitHub Pages, never from Surge — exclude
# the whole folder so the deploy size stays small.
web-assets/

# Locally stored raw renders — not part of the published site
assets/Render_*
assets/Rendering_*

# Unreferenced source videos in assets/ — the live site only plays the
# frame-sequence JPGs under frames/<slug>/. Keep the reference clips
# locally but never ship them. Whitelist loader.* + logo.svg explicitly
# because those ARE referenced from index.html.
assets/*.mp4
assets/*.mov
assets/*.mkv
assets/*.MP4
assets/*.MOV
# Re-include only the preloader clip and the logo. Project videos are
# hosted as GitHub Release assets at
# https://github.com/emiloooooo/nimmersatt-webseite/releases/tag/videos-v1
# and loaded from those URLs by the player, so shipping them in the
# Surge bundle would just bloat deploys without benefit.
!assets/loader.mp4
!assets/loader.webm
!assets/logo.svg

# Folders that held reference clips with spaces or special chars
assets/BL00d+T3Arz+F@Ll! (filler)

# System / editor noise
.DS_Store
.claude/
.git/
node_modules/

# Legacy top-level placeholder frames — superseded by frames/<slug>/ per-section sequences
frames/frame0*.jpg

# Local working folders / scripts
assets/Nimmersatt Ton.mp3
video/
frames/**/*.psd
extract-frames.sh
convert-frames.sh
png-to-svg.py
claude.md
CLAUDE.md
_deploy.sh
